# === Server ===
PORT=8082
GIN_MODE=release

# === Database PostgreSQL (sama dengan yang dipakai n8n) ===
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSLMODE=disable

# === Google Gemini Embedding API ===
# Isi dengan API key dari Google AI Studio / Gemini
# Key ini yang sebelumnya tersimpan di n8n credential store
GEMINI_API_KEY=

# === Embedding Config ===
# Accepts either gemini-embedding-2 or models/gemini-embedding-2.
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
# Optional. Leave 0 for Gemini default. Set to match n8n_vectors.embedding dimension if needed.
GEMINI_OUTPUT_DIMENSIONALITY=0
EMBEDDING_BATCH_SIZE=10

# === Chunking Config ===
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# === Upload Limits ===
TEXT_MAX_LENGTH=50000
PDF_MAX_SIZE_BYTES=20971520
PDF_MAX_PAGES=50

# === Auth (opsional: validasi Bearer token dari frontend) ===
# Jika kosong, endpoint tidak memvalidasi token
# Jika diisi, backend akan verifikasi token ke API utama
AUTH_API_URL=http://194.233.79.180:8080/api/auth/me
